@startuml Diagrama_Clases_Diseno

top to bottom direction
skinparam packageStyle rectangle
hide empty members

package "Interfaces" {

  class CorreoExchangeOnline {
    + asunto: String
    + remitente: String
    + cuerpo: String
    + fechaRecepcion: DateTime
  }

  class FormularioMicrosoftForms {
    + idFormulario: String
    + respuestas: String
    + fechaEnvio: DateTime
  }

  class SolicitudesViewPowerBI {
    + mostrarSolicitudes(): List<Solicitud>
    + mostrarFormularios(): List<Formulario>
    + mostrarHistoricoCorreos(): List<CorreoRecibido>
    + filtrarDatos(): void
  }
}

package "Controladores" {

  class RecibirSolicitudController {
    + recibirCorreo(correo: CorreoExchangeOnline): void
    + evaluarAsunto(asunto: String): String
    + analizarPeticion(correo: CorreoExchangeOnline): String
    + registrarCorreo(correo: CorreoRecibido): void
    + consultarInformacion(numero: String): String
    + generarRespuesta(datos: String): String
    + generarRespuestaPlantilla(intencion: String): String
    + enviarRespuesta(respuesta: String): void
    + registrarSolicitud(solicitud: Solicitud): void
  }

  class RecibirFormularioController {
    + recibirFormulario(formulario: FormularioMicrosoftForms): void
    + evaluarDocumentacion(formulario: Formulario): Boolean
    + enviarInstruccionesDocumentacion(): void
    + registrarFormulario(formulario: Formulario): void
  }
}

package "Modelos" {

  class CorreoRecibido {
    + idCorreo: int
    + fechaRecepcion: DateTime
    + intencion: String
  }

  class Solicitud {
    + numero: String
    + provincia: String
    + tecnico: String
    + eecc: String
    + totalConsultas: int
  }

  class Formulario {
    + id: int
    + idFormulario: int
    + idSolicitud: int
    + estado: boolean
    + fechaEnvio: DateTime
    + fechaResolucion: DateTime
    + respuestas: String
    + documentacionMarcada: Boolean
  }
}

package "Servicios Externos" {

  class ExchangeOnlineService {
    + detectarNuevoCorreo(): CorreoExchangeOnline
    + enviarCorreo(destinatario: String, asunto: String, cuerpo: String): void
    + moverCorreo(carpeta: String): void
  }

  class MicrosoftFormsService {
    + detectarFormularioCompletado(): FormularioMicrosoftForms
    + obtenerRespuestas(idFormulario: String): FormularioMicrosoftForms
  }

  class BaseDatos {
    + consultarDatos(numero: String): String
  }

  class RepositorioDatos {
    + guardarCorreo(correo: CorreoRecibido): void
    + guardarSolicitud(solicitud: Solicitud): void
    + guardarFormulario(formulario: Formulario): void
    + obtenerCorreos(): List<CorreoRecibido>
    + obtenerSolicitudes(): List<Solicitud>
    + obtenerFormularios(): List<Formulario>
  }
}

CorreoExchangeOnline --> RecibirSolicitudController
FormularioMicrosoftForms --> RecibirFormularioController

RecibirSolicitudController --> CorreoRecibido
RecibirSolicitudController --> Solicitud
RecibirFormularioController --> Formulario

RecibirSolicitudController --> ExchangeOnlineService
RecibirSolicitudController --> BaseDatos
RecibirSolicitudController --> RepositorioDatos

RecibirFormularioController --> MicrosoftFormsService
RecibirFormularioController --> ExchangeOnlineService
RecibirFormularioController --> RepositorioDatos

Solicitud "1" -- "0..*" Formulario

SolicitudesViewPowerBI --> RepositorioDatos
SolicitudesViewPowerBI --> Solicitud
SolicitudesViewPowerBI --> Formulario
SolicitudesViewPowerBI --> CorreoRecibido

@enduml