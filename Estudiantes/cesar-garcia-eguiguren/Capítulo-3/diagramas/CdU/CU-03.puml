@startuml secuencia_cu03
!theme plain
skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam sequenceParticipantBackgroundColor #141824
skinparam sequenceParticipantBorderColor #2A3850
skinparam sequenceParticipantFontColor #E2E8F5
skinparam sequenceActorBackgroundColor #1E2840
skinparam sequenceActorBorderColor #38BDF8
skinparam sequenceLifeLineBorderColor #2A3850
skinparam noteBackgroundColor #141824
skinparam noteBorderColor #38BDF8
skinparam sequenceGroupBackgroundColor #0D1018
skinparam sequenceGroupBorderColor #2A3850
skinparam sequenceGroupFontColor #38BDF8
skinparam sequenceGroupHeaderFontColor #38BDF8
skinparam sequenceGroupBodyBackgroundColor #0D1018
skinparam sequenceDividerBackgroundColor #141824
skinparam sequenceDividerBorderColor #2A3850
skinparam sequenceDividerFontColor #38BDF8

actor "Usuario\n(Responsable / Director)" as U

participant "React SPA" as FE
participant "Route\n(Controlador)" as ROUTE
participant "Auth\nMiddleware" as AUTH
participant "Service\n(Lógica)" as SVC
participant "Repository\n(Datos)" as REPO
participant "PostgreSQL\n(Odoo)" as DB

== Paso 1: Ficha del empleado == 

U -> FE : navega a /empleados/{id}\n
FE -> ROUTE : GET /employees/{id}
ROUTE -> AUTH : require_manager_or_above()
AUTH -> AUTH : decode_token(token)\nextraer role, employee_ids,\ndepartment_ids, project_ids
AUTH --> ROUTE : CurrentUser(role, employee_ids, ...)
note right of AUTH
  **CAPA 1 — Guard de rol**
  Bloquea si role == "empleado"
end note

ROUTE -> SVC : EmployeeService.get_employee(cu, employee_id)
SVC -> SVC : verify_employee_scope(cu, employee_id)
note right of SVC
  **CAPA 2 — Verificación individual**
  cu.has_employee_access(id):
    Director → True siempre
    Responsable → id in cu.employee_ids
  403 si no tiene acceso
end note

SVC -> REPO : get_employee_by_id(db, employee_id)
REPO -> DB : SELECT hr_employee JOIN hr_department\nWHERE id = :employee_id
DB --> REPO : row
REPO --> SVC : Employee row
SVC --> ROUTE : EmployeeDetail
ROUTE --> FE : 200 OK + JSON

== Paso 2: Dashboard del empleado ==

FE -> ROUTE : GET /dashboards/summary/employee/{id}
ROUTE -> AUTH : require_manager_or_above()
AUTH -> AUTH : decode_token(token)\nextraer role, employee_ids, ...
AUTH --> ROUTE : CurrentUser(role, employee_ids, ...)

ROUTE -> SVC : DashboardService.get_employee_summary(cu, employee_id)
SVC -> SVC : verify_employee_scope(cu, employee_id)
note right of SVC
  **CAPA 2 — segunda verificación**
  Misma comprobación: id in cu.employee_ids
  Evita acceso por ruta directa al dashboard
end note

SVC -> SVC : WorkloadService.calculate(employee_id, detailed=True)
note right of SVC
  El employee_id ya fue validado por scope.
  Las queries siguientes no necesitan
  re-filtrar por scope: van por user_id
end note

SVC -> REPO : get_assigned_open_tasks(db, user_id)
REPO -> DB : SELECT tareas abiertas asignadas al user_id
DB --> REPO : rows
REPO --> SVC : pending_rows

SVC -> REPO : get_assigned_closed_tasks(db, user_id, date_from=cutoff)
REPO -> DB : SELECT tareas cerradas recientes del user_id
DB --> REPO : rows
REPO --> SVC : completed_rows

SVC -> SVC : WIPService.calculate(employee_id)
SVC -> REPO : count_open_assigned_tasks(db, user_id)
REPO -> DB : SELECT COUNT tareas abiertas
DB --> REPO : count
REPO --> SVC : wip_count

SVC -> SVC : ProductivityService.calculate(employee_id, date_from, date_to)
SVC -> REPO : get_completed_tasks_with_hours(db, employee_id, ...)
REPO -> DB : SELECT tareas cerradas + horas
DB --> REPO : rows
REPO --> SVC : task rows

SVC --> ROUTE : EmployeeSummaryResponse
ROUTE --> FE : 200 OK + JSON

== Paso 3 (opcional): Carga de tareas al seleccionar pestaña ==

opt Selección de pestaña Pendientes / Completadas / Asignadas / Responsable
  FE -> ROUTE : GET /tasks/filter?employee_id={id}&status=<modo>
  ROUTE -> AUTH : require_manager_or_above()
  AUTH -> AUTH : decode_token(token)
  AUTH --> ROUTE : CurrentUser(role, employee_ids, project_ids)

  ROUTE -> SVC : TaskService.filter_tasks(cu, employee_id, status, ...)
  SVC -> SVC : verify_employee_exists + verify_employee_scope(cu, employee_id)
  note right of SVC
    **CAPA 2 — tercera verificación**
    Responsable: employee_id debe estar
    en cu.employee_ids del JWT
  end note

  SVC -> SVC : effective_project_ids = None
  SVC -> REPO : build_filtered_query(db, employee_id, status, ...)
  REPO -> DB : SELECT project_task JOIN assignments
  DB --> REPO : rows
  REPO --> SVC : Query result

  SVC -> REPO : get_worked_hours_batch(db, task_ids)
  REPO -> DB : SELECT SUM horas por tarea
  DB --> REPO : hours_map
  REPO --> SVC : hours_map

  SVC -> SVC : _build_items(tasks, status, employee_id, hours_map)
  SVC --> ROUTE : PaginatedResponse[TaskItem]
  ROUTE --> FE : 200 OK + JSON
end
FE --> U : renderiza los items de la pestaña
@enduml