@startuml CU-08_Tareas_Filtradas
!theme plain
skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam sequenceParticipantBackgroundColor #141824
skinparam sequenceParticipantBorderColor #2A3850
skinparam sequenceParticipantFontColor #E2E8F5
skinparam sequenceActorBackgroundColor #1E2840
skinparam sequenceActorBorderColor #38BDF8
skinparam sequenceLifeLineBorderColor #2A3850
skinparam noteBackgroundColor #141824
skinparam noteBorderColor #38BDF8
skinparam sequenceGroupBackgroundColor #0D1018
skinparam sequenceGroupBorderColor #2A3850
skinparam sequenceGroupFontColor #38BDF8
skinparam sequenceGroupHeaderFontColor #38BDF8
skinparam sequenceGroupBodyBackgroundColor #0D1018

title CU-08 · Consulta de Tareas con Filtros y Scope

actor "Usuario\n(Responsable / Director)" as U
participant "React SPA\n(TaskView)" as FE
participant "TaskRoute\n(Controlador)" as ROUTE
participant "AuthMiddleware" as AUTH
participant "TaskService" as SVC
participant "TaskRepository" as REPO
database "PostgreSQL\n(Odoo)" as DB

U -> FE : abre pantalla tareas\n+ aplica filtros
FE -> ROUTE : GET /tasks/filter\n(status, project_id, employee_id, ...)

ROUTE -> AUTH : require_manager_or_above()
AUTH -> AUTH : decode_token(token)\nrole + scopes
AUTH --> ROUTE : CurrentUser

note right of AUTH
**CAPA 1 — Control de acceso**
Bloquea si role == "employee"
end note

ROUTE -> SVC : filter_tasks(cu, filtros)

SVC -> SVC : validar parámetros opcionales

note right of SVC
**CAPA 2 — Validación de scope**
- employee_id → pertenece a cu.employee_ids
- project_id → pertenece a cu.project_ids
- department_id → validación adicional
end note

SVC -> SVC : calcular effective_project_ids

note right of SVC
**CAPA 3 — Scope final**
- Responsable sin employee_id:
  usa cu.project_ids
- Director o con employee_id:
  sin restricción de proyecto
end note

SVC -> REPO : build_filtered_query(\nproject_ids, employee_id, status,...)

note right of REPO
Se traduce a SQL:
WHERE project_id IN (:scope_ids)
AND filtros adicionales
end note

REPO -> DB : SELECT tasks\nJOIN relations\nWHERE condiciones...

DB --> REPO : rows
REPO --> SVC : query object

SVC -> REPO : paginate(query, page, size)
REPO -> DB : SELECT COUNT(*) + LIMIT/OFFSET
DB --> REPO : resultados paginados
REPO --> SVC : {items, total}

SVC -> REPO : get_worked_hours_batch(task_ids)
REPO -> DB : SUM(unit_amount)\nGROUP BY task_id
DB --> REPO : horas por tarea
REPO --> SVC : hours_map

SVC -> SVC : construir respuesta final\n(pending/completed/assigned)

SVC --> ROUTE : PaginatedResponse
ROUTE --> FE : 200 OK + JSON
FE --> U : render lista filtrada con tareas + paginación

@enduml