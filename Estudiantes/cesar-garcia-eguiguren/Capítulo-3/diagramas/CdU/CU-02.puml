@startuml secuencia_cu02
!theme plain
skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam sequenceParticipantBackgroundColor #141824
skinparam sequenceParticipantBorderColor #2A3850
skinparam sequenceParticipantFontColor #E2E8F5
skinparam sequenceActorBackgroundColor #1E2840
skinparam sequenceActorBorderColor #38BDF8
skinparam sequenceLifeLineBorderColor #2A3850
skinparam noteBackgroundColor #141824
skinparam noteBorderColor #38BDF8
skinparam sequenceGroupBackgroundColor #0D1018
skinparam sequenceGroupBorderColor #2A3850
skinparam sequenceGroupFontColor #38BDF8
skinparam sequenceGroupHeaderFontColor #38BDF8
skinparam sequenceGroupBodyBackgroundColor #0D1018
skinparam sequenceDividerBackgroundColor #141824
skinparam sequenceDividerBorderColor #2A3850
skinparam sequenceDividerFontColor #38BDF8

actor "Usuario\n(Responsable / Director)" as U

participant "React SPA" as FE
participant "Route\n(Controlador)" as ROUTE
participant "Auth\nMiddleware" as AUTH
participant "Service\n(Lógica)" as SVC
participant "Repository\n(Datos)" as REPO
participant "PostgreSQL\n(Odoo)" as DB

U -> FE : navega a /empleados\n+ ajusta filtro
FE -> ROUTE : GET /employees/?department_id=X&search=Y\n&sort_by=name&page=1&page_size=50

ROUTE -> AUTH : require_manager_or_above()
AUTH -> AUTH : decode_token(token)\nextraer role, employee_ids,\ndepartment_ids, project_ids
AUTH --> ROUTE : CurrentUser(role, employee_ids, department_ids)
note right of AUTH
  **CAPA 1 — Guard de rol**
  Bloquea si role == "empleado"
  Igual en todas las rutas del sistema
end note

ROUTE -> SVC : EmployeeService.list_employees(\n  cu, department_id, search,\n  active, sort_by, sort_order,\n  page, page_size)

SVC -> SVC : [si department_id]\nverify_department_exists(db, department_id)\nverify_department_scope(cu, department_id)
note right of SVC
  **CAPA 2 — Verificación individual**
  Solo si se filtra por departamento concreto.
  Responsable: department_id in cu.department_ids
  403 si no tiene acceso al departamento
end note

SVC -> SVC : Calcular emp_ids según rol
note right of SVC
  **CAPA 3 — Filtrado de scope**
  if cu.is_responsable AND NOT department_id:
    emp_ids = cu.employee_ids
    ← Solo empleados del JWT del responsable
  else (director o department_id dado):
    emp_ids = None
    ← Sin restricción adicional de empleados
end note

SVC -> REPO : get_filtered_employees_query(db,\n  employee_ids=emp_ids,\n  department_id=department_id,\n  search=search,\n  active=active,\n  sort_by=sort_by,\n  sort_order=sort_order)
note right of REPO
  Si employee_ids is not None:
    WHERE id IN (:emp_ids)
  Si department_id:
    WHERE department_id = :id
  Si search:
    WHERE name ILIKE :term
  ORDER BY :sort_by :sort_order
  Siempre: WHERE active = True
end note

REPO -> DB : SELECT hr_employee\n  LEFT JOIN hr_department\nWHERE active = True\n  AND [id IN (:emp_ids)]\n  AND [department_id = :dept]\n  AND [name ILIKE :search]\nORDER BY :sort_by
DB --> REPO : rows
REPO --> SVC : query (sin paginar)

SVC -> SVC : paginate(query, page, page_size)\nCOUNT(*) + OFFSET/LIMIT
SVC --> ROUTE : PaginatedResponse[EmployeeDetail] {\n  items, total, page,\n  page_size, total_pages }
ROUTE --> FE : 200 OK + JSON
FE --> U : renderiza la lista de empleados con paginación
@enduml