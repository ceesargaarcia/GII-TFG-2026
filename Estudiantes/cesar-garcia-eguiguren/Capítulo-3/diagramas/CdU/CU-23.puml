@startuml secuencia_cu23
!theme plain
skinparam backgroundColor #07090F
skinparam sequenceArrowColor #38BDF8
skinparam sequenceParticipantBackgroundColor #141824
skinparam sequenceParticipantBorderColor #2A3850
skinparam sequenceLifeLineBorderColor #1E2840
skinparam noteBorderColor #2A3850
skinparam noteBackgroundColor #141824
skinparam noteFontColor #E2E8F5
skinparam defaultFontColor #E2E8F5
skinparam sequenceGroupBackgroundColor #0D1018
skinparam sequenceGroupBorderColor #2A3850
skinparam sequenceGroupFontColor #38BDF8
skinparam sequenceGroupHeaderFontColor #38BDF8
skinparam sequenceGroupBodyBackgroundColor #0D1018

participant "React SPA" as FE
participant "Route\n(Controlador)" as ROUTE
participant "Auth\nMiddleware" as AUTH
participant "Service\n(Lógica)" as SVC
participant "Repository\n(Datos)" as REPO
participant "PostgreSQL\n(Odoo)" as DB

FE -> ROUTE : GET /metrics/profitability/summary\n?date_from=X&date_to=Y
ROUTE -> AUTH : require_director()
AUTH -> AUTH : decode_token(token)\nextraer role
AUTH --> ROUTE : CurrentUser(role=director, ...)
note right of AUTH
  **CAPA 1 — Guard de rol estricto**
  require_director(): solo role == "director"
  403 si role == "responsable" o "empleado"
  No hay Capa 3: el director siempre ve
  todos los datos financieros globales
end note

ROUTE -> SVC : RentabilityService.get_summary(\n  date_from, date_to)
note right of SVC
  Sin Capa 2 ni Capa 3:
  La rentabilidad financiera es un dato
  exclusivo del director. El guard de rol
  en la ruta es la única barrera de acceso.
  El servicio opera sin restricción de scope.
end note

SVC -> REPO : get_global_totals(db, date_from, date_to)
REPO -> DB : SELECT\n  SUM(CASE WHEN amount > 0 THEN amount END) income,\n  SUM(CASE WHEN amount < 0 THEN amount END) expense,\n  SUM(amount) net,\n  SUM(unit_amount) total_hours\nFROM account_analytic_line\nWHERE project_id IS NOT NULL\n  AND amount IS NOT NULL\n  AND [date BETWEEN :from AND :to]
DB --> REPO : row (income, expense, net, total_hours)
REPO --> SVC : totals row

SVC -> REPO : get_profitability_by_project(db,\n  date_from, date_to)
REPO -> DB : SELECT project_id,\n  SUM(income) income,\n  SUM(expense) expense,\n  SUM(net) net,\n  SUM(unit_amount) total_hours\nFROM account_analytic_line\nWHERE project_id IS NOT NULL\nGROUP BY project_id\n  AND [date BETWEEN :from AND :to]
DB --> REPO : rows por proyecto
REPO --> SVC : project rows

SVC -> SVC : Para cada proyecto:\n  pct = net / income * 100\n  status = ganancia / neutro / perdida\nContar proyectos por estado

SVC -> REPO : get_project_meta(db, project_ids)
REPO -> DB : SELECT project_project JOIN res_partner\nWHERE id IN (:project_ids)
DB --> REPO : nombre y cliente por proyecto
REPO --> SVC : meta dict

SVC --> ROUTE : summary {\n  income, expense, net,\n  total_hours, profitability_pct,\n  status,\n  projects_summary: {\n    ganancia, neutro, perdida, total\n  }\n}
ROUTE --> FE : 200 OK + JSON

opt Director navega a detalle por proyecto
  FE -> ROUTE : GET /metrics/profitability/per-project\n?date_from=X&date_to=Y&project_id=Z&manager_id=W
  ROUTE -> AUTH : require_director()
  AUTH --> ROUTE : CurrentUser(role=director)
  ROUTE -> SVC : RentabilityService.get_per_project(\n  date_from, date_to, project_id, manager_id)
  SVC -> REPO : get_profitability_by_project(db,\n  project_id, manager_id, date_from, date_to)
  REPO -> DB : SELECT ... WHERE [project_id = :id]\n  AND [manager_id = :mid]\n  AND [date BETWEEN :from AND :to]
  DB --> REPO : rows
  REPO --> SVC : project rows
  SVC -> REPO : get_project_meta(db, project_ids)
  REPO -> DB : SELECT nombre y cliente
  DB --> REPO : meta
  REPO --> SVC : meta dict
  SVC --> ROUTE : lista de proyectos con\n  income, expense, net,\n  profitability_pct, status
  ROUTE --> FE : 200 OK + JSON
end
@enduml
