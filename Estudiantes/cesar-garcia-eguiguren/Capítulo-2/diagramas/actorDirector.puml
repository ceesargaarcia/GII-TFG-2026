@startuml ActorDirector
!theme plain
left to right direction

skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam NoteBackgroundColor #2c354e
skinparam usecase {
  BackgroundColor #141824
  BorderColor #2A3850
  FontColor #E2E8F5
}
skinparam actor {
  BackgroundColor #1E2840
  BorderColor #38BDF8
  FontColor #E2E8F5
}
skinparam package {
  BackgroundColor #0D1018
  BorderColor #2A3850
  FontColor #38BDF8
  FontStyle bold
}

actor "Director" as D

package "P1 · Autenticación" {
  usecase "CU-01\nAutenticarse" as CU01
  usecase "CU-16\nCerrar Sesión" as CU16
}

package "P2–P5 · Entidades operativas [scope]" {
  usecase "CU-02 Listar empleados" as CU02
  usecase "CU-03 Consultar resumen empleado" as CU03
  usecase "CU-04 Listar departamentos" as CU04
  usecase "CU-05 Consultar resumen departamento" as CU05
  usecase "CU-06 Listar proyectos" as CU06
  usecase "CU-07 Consultar resumen proyecto" as CU07
  usecase "CU-08 Listar tareas" as CU08
  usecase "CU-09 Consultar detalle tarea" as CU09
}

package "P6 · Análisis" {
  usecase "CU-10 Consultar métrica operativa" as CU10
  usecase "CU-11 Consultar gráficos analíticos" as CU11
  usecase "CU-12 Consultar asistencia vs imputaciones" as CU12
  usecase "CU-21 Consultar carga de trabajo del equipo" as CU21
}

package "P7 · Rentabilidad" #1A0A0A {
  usecase "CU-13 Consultar rentabilidad Financiera ★" as CU13
  usecase "CU-14 Listar líneas analíticas ★\n(scope: proyecto | cliente)" as CU14
}

package "P8 · Utilidades" {
  usecase "CU-15 Realizar búsqueda global" as CU15
}

package "P9 · Snapshots" #0F1E2A {
  usecase "CU-17 Guardar Snapshot\n(upsert diario)" as CU17
  usecase "CU-18 Listar Snapshots" as CU18
  usecase "CU-19 Consultar Detalle Snapshot" as CU19
  usecase "CU-20 Eliminar Snapshot" as CU20
}

D --> CU01
D --> CU02
D --> CU03
D --> CU04
D --> CU05
D --> CU06
D --> CU07
D --> CU08
D --> CU09
D --> CU10
D --> CU11
D --> CU12
D --> CU13
D --> CU14
D --> CU15
D --> CU16
D --> CU17
D --> CU18
D --> CU19
D --> CU20
D --> CU21


note right of CU10
  CU único parametrizado por métrica.
end note

note right of CU14
  CU único parametrizado por scope
  (proyecto o cliente). Mismo flujo y
  misma postcondición; solo cambia la
  agregación de las líneas analíticas.
end note

note right of CU17
  Upsert atómico. Si ya existe snapshot
  para (tipo, params_hash, snapshot_date),
  la sobrescribe. No existe CU de
  "Actualizar" separado — FA-01 de CU-17.
end note

@enduml
