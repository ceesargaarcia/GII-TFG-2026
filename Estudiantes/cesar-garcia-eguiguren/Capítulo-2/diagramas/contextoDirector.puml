@startuml ContextoDirector
!theme plain

skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam ArrowFontColor #8896A8
skinparam ArrowFontSize 9
skinparam usecase {
  BackgroundColor #141824
  BorderColor #2A3850
  FontColor #E2E8F5
  FontSize 10
}
skinparam actor {
  BackgroundColor #1E2840
  BorderColor #38BDF8
  FontColor #E2E8F5
}
skinparam package {
  BackgroundColor #0D1018
  BorderColor #2A3850
  FontColor #38BDF8
  FontSize 11
  FontStyle bold
}

top to bottom direction
actor Director as D

package "Autenticación" {
  usecase "CU-01\nAutenticarse" as CU01
  usecase "CU-16\nCerrar Sesión" as CU16
}

package "Empleados" {
  usecase "CU-02\nListar y Buscar Empleados" as CU02
  usecase "CU-03\nResumen de Empleado" as CU03
  CU02 -down-> CU03 : selecciona un empleado
}

package "Departamentos" {
  usecase "CU-04\nListar Departamentos" as CU04
  usecase "CU-05\nResumen de Departamento" as CU05
  CU04 -down-> CU05 : selecciona un departamento
}

package "Proyectos" {
  usecase "CU-06\nListar Proyectos" as CU06
  usecase "CU-07\nResumen de Proyecto" as CU07
  CU06 -down-> CU07 : selecciona un proyecto
}

package "Tareas" {
  usecase "CU-08\nListar y Filtrar Tareas" as CU08
  usecase "CU-09\nDetalle de Tarea" as CU09
  CU08 -down-> CU09 : selecciona una tarea
}

package "Métricas Operativas" {
  usecase "CU-10\nConsultar Métrica Operativa\n(15 servicios · individual/equipo)" as CU10
}

package "Análisis Visual" {
  usecase "CU-11\nVer Gráficos Analíticos" as CU11
  usecase "CU-12\nConsultar Asistencia" as CU12
}

package "Rentabilidad  ★ Director exclusivo" #1A0A0A {
  usecase "CU-13\nConsultar Rentabilidad Financiera" as CU13
  usecase "CU-14\nVer Líneas Analíticas\n(proyecto y cliente)" as CU14
  CU13 -down-> CU14 : "Ver detalles"
}

package "Utilidades" {
  usecase "CU-15\nBúsqueda Global" as CU15
}

package "Snapshots (MongoDB)" #0F1E2A {
  usecase "CU-17\nGuardar Snapshot\n(upsert diario)" as CU17
  usecase "CU-18\nListar Snapshots" as CU18
  usecase "CU-19\nDetalle de Snapshot" as CU19
  usecase "CU-20\nEliminar Snapshot" as CU20

  CU18 -down-> CU19 : selecciona fila
  CU19 -right-> CU20 : pulsa "Eliminar"
}

D -down-> CU01 : login
D -down-> CU16 : logout
D --> CU02
D --> CU04
D --> CU06
D --> CU08
D --> CU10
D --> CU11
D --> CU12
D --> CU13
D --> CU15
D --> CU17 : guardar desde vista calculada
D --> CU18 : acceder al visor (frontend2)

CU05 -right-> CU03 : empleado del depart.
CU07 -up-> CU03 : empleado del equipo
CU03 -down-> CU08 : ver sus tareas
CU07 -down-> CU08 : tareas del proyecto
CU09 -up-> CU07 : proyecto de la tarea
CU09 -left-> CU03 : responsable/asignado

CU03 .down.> CU10 : KPIs del empleado
CU05 .down.> CU10 : workload depart.
CU07 .down.> CU10 : eficiencia/riesgo proyecto

CU10 ..down..> CU17 : guardar métrica
"Análisis Visual" ..down..> CU17 : guardar gráfico
"Rentabilidad  ★ Director exclusivo" .down.> CU17 : guardar rentabilidad
CU03 ..down..> CU17 : guardar entidad (empl.)
CU05 ..down..> CU17 : guardar entidad (depart.)
CU07 ..down..> CU17 : guardar entidad (proy.)
CU09 ..down..> CU17 : guardar entidad (tarea)

CU15 --> CU03
CU15 --> CU07
CU15 --> CU09

@enduml
