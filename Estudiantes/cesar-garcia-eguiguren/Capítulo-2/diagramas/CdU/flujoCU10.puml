@startuml flujoCU10
!theme plain
skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam ActivityBorderColor #1E2840
skinparam ActivityBackgroundColor #141824
skinparam ActivityDiamondBackgroundColor #0D1018
skinparam ActivityDiamondBorderColor #38BDF8
skinparam NoteBackgroundColor #141824
skinparam NoteBorderColor #38BDF8

title CU-10 · Consultar Métrica Operativa (parametrizada)

start
:El actor accede a la página de métricas;
:El sistema muestra la cuadrícula de métricas
agrupadas por categoría
(proyecto · empleado · equipo · generales);
:El actor selecciona una métrica;

:El actor configura los parámetros que requiera:
· employee_id (WIP, Workload indiv., Estimation…)
· project_id  (Efficiency, Risk, Profitability…)
· department_id (Workload de equipo — opcional)
· rango de fechas · root_only;

note right
  El mismo CU sirve a los **15 servicios** del
  backend. Los parámetros obligatorios dependen
  de la métrica elegida. El modo de **Workload**
  es individual si se envía employee_id, o
  agregado de equipo en caso contrario.
end note

if (¿Parámetro obligatorio faltante?) then (SÍ)
  :El sistema muestra un estado vacío
  indicando el parámetro necesario;
  stop
else (NO)
  :El sistema verifica que los parámetros
  están dentro del ámbito del actor;
  if (¿Parámetros fuera del ámbito?) then (SÍ)
    :HTTP 403 - Acceso denegado;
    stop
  else (NO)
    :El sistema delega en el servicio
    de la métrica seleccionada;

    if (¿Datos suficientes?) then (NO)
      :Panel vacío con mensaje "sin datos";
      stop
    else (SÍ)
      :Muestra panel de detalle de la métrica;
      if (¿Pulsar "Guardar snapshot"?) then (SÍ)
        :<<extend>> CU-17 Guardar Snapshot;
      endif
      stop
    endif
  endif
endif

note right
  FA-01: parámetro obligatorio faltante → estado vacío
  FA-02: parámetros fuera de ámbito → HTTP 403
  FA-03: sin datos → panel vacío
end note

@enduml
