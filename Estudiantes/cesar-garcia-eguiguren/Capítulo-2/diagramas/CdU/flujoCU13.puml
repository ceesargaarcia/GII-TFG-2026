@startuml flujoCU13
!theme plain
skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam ActivityBorderColor #1E2840
skinparam ActivityBackgroundColor #141824
skinparam ActivityDiamondBackgroundColor #0D1018
skinparam ActivityDiamondBorderColor #38BDF8
skinparam NoteBackgroundColor #141824
skinparam NoteBorderColor #38BDF8

title CU-13 · Analizar Rentabilidad Financiera (Director exclusivo)

start
:El actor intenta acceder a la página
de rentabilidad;

if (¿Director?) then (NO)
  :Pantalla de acceso restringido
  (HTTP 403);
  stop
else (SÍ)
  :Configura filtros:
  · Rango de fechas
  · Modo (Global / Por proyecto / Por responsable);

  :El sistema muestra el resumen financiero:
  · Ingresos / Gastos / Resultado neto
  · Rentabilidad (%)
  · Gráfico comparativo por proyecto
  · Distribución ganancia/neutro/pérdida;

  :Selecciona una pestaña de desglose;

  if (Pestaña) then (Por proyecto)
    :Muestra tabla de rentabilidad por proyecto;
    if (¿"Ver detalles" de un proyecto?) then (SÍ)
      :<<extend>> CU-14 Líneas Analíticas
      (scope = proyecto);
    endif
  else (Por cliente)
    :Muestra tabla de rentabilidad por cliente;
    if (¿"Ver detalles" de un cliente?) then (SÍ)
      :<<extend>> CU-14 Líneas Analíticas
      (scope = cliente);
    endif
  endif

  if (Modo == Por responsable) then (SÍ)
    :Muestra panel de rentabilidad del
    responsable elegido con sus proyectos;
  endif

  if (¿Pulsar "Guardar snapshot"?) then (SÍ)
    :<<extend>> CU-17 Guardar Snapshot
    con el resumen financiero;
  endif
  stop
endif

note right
  FA-01: sin partes analíticos → indicadores a 0
  FA-02: actor no Director → 403
end note

@enduml
