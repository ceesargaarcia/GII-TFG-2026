@startuml flujoCU12
!theme plain
skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam ActivityBorderColor #1E2840
skinparam ActivityBackgroundColor #141824
skinparam ActivityDiamondBackgroundColor #0D1018
skinparam ActivityDiamondBorderColor #38BDF8
skinparam NoteBackgroundColor #141824
skinparam NoteBorderColor #38BDF8

title CU-12 · Consultar Asistencia vs Imputaciones

start
:El actor accede a la página de asistencia;
:El sistema carga los datos del período actual
por defecto;

:El actor configura:
· Rango de fechas
· Departamento (opcional);

if (¿Director?) then (SÍ)
  :Puede elegir modo de visualización:
  · Equipo global
  · Por responsable de área;

  if (Modo elegido) then (Por responsable)
    :Selecciona un responsable del listado;
    if (¿Responsable elegido?) then (NO)
      :Solicita seleccionar uno;
      stop
    endif
  endif
endif

:Compara horas fichadas vs horas imputadas
en partes de horas por empleado del ámbito;

if (¿Datos en el período?) then (NO)
  :Muestra indicadores a cero
  y tabla vacía;
  stop
else (SÍ)
  :Muestra:
  · Indicadores globales del equipo
  · Gráfico comparativo por empleado
  · Tabla de cobertura individual con semáforo;

  if (¿Selecciona un empleado?) then (SÍ)
    :Muestra serie diaria de horas fichadas
    vs imputadas para el empleado elegido;
  endif
  stop
endif

note right
  FA-01: sin datos → indicadores a 0
  FA-02: Responsable → solo modo equipo global
end note

@enduml
