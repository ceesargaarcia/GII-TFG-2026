@startuml flujoCU15
!theme plain
skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam ActivityBorderColor #1E2840
skinparam ActivityBackgroundColor #141824
skinparam ActivityDiamondBackgroundColor #0D1018
skinparam ActivityDiamondBorderColor #38BDF8
skinparam NoteBackgroundColor #141824
skinparam NoteBorderColor #38BDF8

title CU-15 · Realizar Búsqueda Global

start
:El actor accede a la búsqueda global;
:Introduce el texto a buscar;

if (¿Mínimo 2 caracteres?) then (NO)
  :Solicita más caracteres;
  stop
else (SÍ)
  :El sistema busca coincidencias en:
  · Tareas (nombre o código)
  · Proyectos (nombre o código)
  · Empleados (nombre);

  note right
    Responsable → resultados solo dentro
    de su ámbito; Director → globales.
  end note

  if (¿Resultados?) then (NO)
    :Estado vacío, sin coincidencias;
    stop
  else (SÍ)
    :Muestra resultados agrupados por tipo;
    :El actor puede filtrar por tipo
    (Todos / Tareas / Proyectos / Empleados);
    if (¿Selecciona un resultado?) then (SÍ)
      if (Tipo) then (Tarea)
        :Navega a CU-09 Detalle de Tarea;
      else if (Tipo) then (Proyecto)
        :Navega a CU-07 Resumen de Proyecto;
      else (Empleado)
        :Navega a CU-03 Resumen de Empleado;
      endif
    endif
    stop
  endif
endif

@enduml
