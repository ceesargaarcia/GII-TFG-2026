@startuml flujoCU11
!theme plain
skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #38BDF8
skinparam ActivityBorderColor #1E2840
skinparam ActivityBackgroundColor #141824
skinparam ActivityDiamondBackgroundColor #0D1018
skinparam ActivityDiamondBorderColor #38BDF8
skinparam NoteBackgroundColor #141824
skinparam NoteBorderColor #38BDF8

title CU-11 · Visualizar Gráficos Analíticos

start
:El actor accede a la página de gráficos;
:El sistema carga los selectores de filtro
(empleados, departamentos, proyectos)
según el ámbito del actor;

:El actor configura:
· Rango de fechas
· Agrupación temporal (semana/mes)
· Entidad de análisis
  (empresa · empleado · departamento · proyecto);

:El sistema genera los gráficos disponibles:
· Evolución temporal de tareas
  (completadas, abiertas, vencidas)
· Distribución por estado actual;

if (¿Director?) then (SÍ)
  :Añade distribución de horas por cliente;
endif

if (¿Cambio de filtros?) then (SÍ)
  :Recalcula y refresca todos los gráficos;
endif

if (¿Sin datos en el período?) then (SÍ)
  :Muestra mensaje "sin datos" por gráfico;
endif

if (¿Pulsar "Guardar snapshot" sobre un gráfico?) then (SÍ)
  :<<extend>> CU-17 Guardar Snapshot
  con chart_name + params actuales;
endif

stop

note right
  FA-01: sin datos → mensaje por gráfico
  FA-02: el Responsable no ve la distribución
         por cliente ni datos fuera de su ámbito
end note

@enduml
