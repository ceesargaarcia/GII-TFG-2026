@startuml ContextoResponsable
!theme plain

skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #10B981
skinparam ArrowFontColor #8896A8
skinparam ArrowFontSize 9
skinparam usecase {
  BackgroundColor #141824
  BorderColor #2A3850
  FontColor #E2E8F5
  FontSize 10
}
skinparam actor {
  BackgroundColor #1E2840
  BorderColor #10B981
  FontColor #E2E8F5
}
skinparam package {
  BackgroundColor #0D1018
  BorderColor #2A3850
  FontColor #10B981
  FontSize 11
  FontStyle bold
}

top to bottom direction
actor Responsable as R

package "Autenticación" {
  usecase "CU-01 Autenticarse" as CU01
  usecase "CU-16 Cerrar Sesión" as CU16
}

package "Empleados  [scope]" {
  usecase "CU-02 Listar y Buscar Empleados" as CU02
  usecase "CU-03 Resumen de Empleado" as CU03
  CU02 -down-> CU03
}

package "Departamentos  [scope]" {
  usecase "CU-04 Listar Departamentos" as CU04
  usecase "CU-05 Resumen de Departamento" as CU05
  CU04 -down-> CU05
}

package "Proyectos  [scope]" {
  usecase "CU-06 Listar Proyectos" as CU06
  usecase "CU-07 Resumen de Proyecto" as CU07
  CU06 -down-> CU07
}

package "Tareas  [scope]" {
  usecase "CU-08 Listar y Filtrar Tareas" as CU08
  usecase "CU-09 Detalle de Tarea" as CU09
  CU08 -down-> CU09
}

package "Métricas Operativas" {
  usecase "CU-10\nConsultar Métrica Operativa\n(scope aplicado)" as CU10
}

package "Análisis Visual" {
  usecase "CU-11 Gráficos Analíticos  [scope]" as CU11
  usecase "CU-12 Asistencia\n[solo modo Equipo]" as CU12
}

package "Utilidades" {
  usecase "CU-15 Búsqueda Global  [scope]" as CU15
}

package "Snapshots (MongoDB)" #0F1E2A {
  usecase "CU-17 Guardar Snapshot" as CU17
  usecase "CU-18 Listar Snapshots" as CU18
  usecase "CU-19 Detalle Snapshot" as CU19
  usecase "CU-20 Eliminar Snapshot" as CU20

  CU18 -down-> CU19
  CU19 -right-> CU20
}

R -down-> CU01
R -down-> CU16
R --> CU02
R --> CU04
R --> CU06
R --> CU08
R --> CU10
R --> CU11
R --> CU12
R --> CU15
R --> CU17
R --> CU18

CU05 -right-> CU03
CU07 -up-> CU03
CU03 -down-> CU08
CU07 -down-> CU08
CU09 -up-> CU07
CU09 -left-> CU03

CU03 .down.> CU10
CU05 .down.> CU10
CU07 .down.> CU10

CU10 ..down..> CU17
CU11 ..down..> CU17
CU03 ..down..> CU17
CU05 ..down..> CU17
CU07 ..down..> CU17
CU09 ..down..> CU17

CU15 --> CU03
CU15 --> CU07
CU15 --> CU09

note bottom
  **Ámbito del Responsable:** CU-13 y CU-14
  (Rentabilidad financiera y Líneas analíticas)
  están vetados (HTTP 403). El resto de CUs
  aplica filtrado por scope; los snapshots de
  MongoDB se comparten entre usuarios, pero los
  snapshots de rentabilidad no aparecen porque
  el Responsable no puede generarlos.
end note

@enduml
