@startuml ActorResponsable
!theme plain
left to right direction

skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #10B981
skinparam NoteBackgroundColor #253346
skinparam usecase {
  BackgroundColor #141824
  BorderColor #2A3850
  FontColor #E2E8F5
}
skinparam actor {
  BackgroundColor #1E2840
  BorderColor #10B981
  FontColor #E2E8F5
}
skinparam package {
  BackgroundColor #0D1018
  BorderColor #2A3850
  FontColor #10B981
  FontStyle bold
}

actor "Responsable" as R

package "P1 · Autenticación" {
  usecase "CU-01 Autenticarse" as CU01
  usecase "CU-16 Cerrar Sesión" as CU16
}

package "P2–P5 · Entidades operativas [scope]" {
  usecase "CU-02 Listar Empleados" as CU02
  usecase "CU-03 Resumen Empleado" as CU03
  usecase "CU-04 Listar Departamentos" as CU04
  usecase "CU-05 Resumen Departamento" as CU05
  usecase "CU-06 Listar Proyectos" as CU06
  usecase "CU-07 Resumen Proyecto" as CU07
  usecase "CU-08 Listar Tareas" as CU08
  usecase "CU-09 Detalle Tarea" as CU09
}

package "P6 · Métricas [scope]" {
  usecase "CU-10 Consultar Métrica Operativa" as CU10
}

package "P7 · Análisis visual [scope]" {
  usecase "CU-11 Gráficos Analíticos" as CU11
  usecase "CU-12 Asistencia\n[solo modo equipo global]" as CU12
}

package "P9 · Utilidades" {
  usecase "CU-15 Búsqueda Global [scope]" as CU15
}

package "P10 · Snapshots (MongoDB)" #0F1E2A {
  usecase "CU-17 Guardar Snapshot" as CU17
  usecase "CU-18 Listar Snapshots" as CU18
  usecase "CU-19 Detalle Snapshot" as CU19
}

R --> CU01
R --> CU02
R --> CU03
R --> CU04
R --> CU05
R --> CU06
R --> CU07
R --> CU08
R --> CU09
R --> CU10
R --> CU11
R --> CU12
R --> CU15
R --> CU16
R --> CU17
R --> CU18

' ── Relaciones <<extend>> ─────────────────────────────────────
"P6 · Métricas [scope]" ..> CU17 : <<extend>>
"P7 · Análisis visual [scope]" ..> CU17 : <<extend>>
"P2–P5 · Entidades operativas [scope]" ..> CU17 : <<extend>>


' Visor de snapshots (solo lectura para Responsable)
CU18 ..> CU19 : <<extend>>

note bottom of R
  El Responsable **no** tiene acceso a:
  · CU-13 y CU-14 — Rentabilidad Financiera
    y Líneas Analíticas (exclusivos Director).
  · CU-20 — Eliminar Snapshot (solo Director).
  Cuenta con **17 CU** de un total de 20.
  Todos los CU operativos aplican filtrado
  automático por scope (JWT).
end note

@enduml
