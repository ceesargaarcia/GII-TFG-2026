@startuml ActorResponsable
!theme plain
left to right direction

skinparam backgroundColor #07090F
skinparam defaultFontColor #E2E8F5
skinparam ArrowColor #10B981
skinparam NoteBackgroundColor #253346
skinparam usecase {
  BackgroundColor #141824
  BorderColor #2A3850
  FontColor #E2E8F5
}
skinparam actor {
  BackgroundColor #1E2840
  BorderColor #10B981
  FontColor #E2E8F5
}
skinparam package {
  BackgroundColor #0D1018
  BorderColor #2A3850
  FontColor #10B981
  FontStyle bold
}

actor "Responsable" as R

package "P1 · Autenticación" {
  usecase "CU-01 Autenticarse" as CU01
  usecase "CU-16 Cerrar Sesión" as CU16
}

package "P2–P5 · Entidades operativas [scope]" {
  usecase "CU-02 Listar empleados" as CU02
  usecase "CU-03 Consultar resumen empleado" as CU03
  usecase "CU-04 Listar departamentos" as CU04
  usecase "CU-05 Consultar resumen departamento" as CU05
  usecase "CU-06 Listar proyectos" as CU06
  usecase "CU-07 Consultar resumen proyecto" as CU07
  usecase "CU-08 Listar tareas" as CU08
  usecase "CU-09 Consultar detalle tarea" as CU09
}

package "P6 · Análisis [scope]" {
  usecase "CU-10\nMostrar Catálogo\nde Métricas" as CU10
  usecase "CU-11 Consultar gráficos analíticos" as CU11
  usecase "CU-12 Consultar asistencia vs imputaciones\n(modo equipo global)" as CU12
  usecase "CU-21 Consultar carga de trabajo del equipo" as CU21
}

package "P10 · Métricas Operativas [scope]" {
  usecase "CU-22 Consultar productividad" as CU22
  usecase "CU-23 Consultar cumplimiento de plazos" as CU23
  usecase "CU-24 Consultar WIP de empleado" as CU24
  usecase "CU-25 Consultar carga de trabajo de empleado" as CU25
  usecase "CU-26 Consultar riesgo de proyecto" as CU26
  usecase "CU-27 Consultar tasa de retrabajo" as CU27
  usecase "CU-28 Consultar exactitud de estimación" as CU28
  usecase "CU-29 Consultar lead time" as CU29
  usecase "CU-30 Consultar tiempo por estado" as CU30
  usecase "CU-31 Consultar tareas canceladas" as CU31
  usecase "CU-32 Consultar tiempo invertido por prioridad" as CU32
}

package "P8 · Utilidades" {
  usecase "CU-15 Realizar búsqueda global [scope]" as CU15
}

package "P9 · Snapshots (MongoDB)" #0F1E2A {
  usecase "CU-17 Guardar Snapshot" as CU17
  usecase "CU-18 Listar Snapshots" as CU18
  usecase "CU-19 Detalle Snapshot" as CU19
}

' ── Ancla de layout: fuerza P10 a la derecha de CU-10 ─────────
CU10 -[hidden]right-> CU22

' ── Relaciones <<extend>> P10 → CU-10 ─────────────────────────
CU10 <.. CU22 : <<extend>>
CU10 <.. CU23 : <<extend>>
CU10 <.. CU24 : <<extend>>
CU10 <.. CU25 : <<extend>>
CU10 <.. CU26 : <<extend>>
CU10 <.. CU27 : <<extend>>
CU10 <.. CU28 : <<extend>>
CU10 <.. CU29 : <<extend>>
CU10 <.. CU30 : <<extend>>
CU10 <.. CU31 : <<extend>>
CU10 <.. CU32 : <<extend>>

' ── Conexiones del actor ───────────────────────────────────────
R --> CU01
R --> CU02
R --> CU03
R --> CU04
R --> CU05
R --> CU06
R --> CU07
R --> CU08
R --> CU09
R --> CU10
R --> CU11
R --> CU12
R --> CU15
R --> CU16
R --> CU17
R --> CU18
R --> CU21

note right of CU10
  Punto de entrada al catálogo de métricas.
  Todos los CU de P10 aplican el filtro
  de ámbito del Responsable.
end note

@enduml
