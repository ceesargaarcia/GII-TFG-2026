@startuml
left to right direction

[*] --> DOCUMENTACION_ABIERTA

DOCUMENTACION_ABIERTA --> DOCUMENTO_ABIERTO : crearDocumentacion()
DOCUMENTACION_ABIERTA --> DOCUMENTO_ABIERTO : editarDocumentacion()
DOCUMENTACION_ABIERTA --> DOCUMENTO_ABIERTO : eliminarDocumentacion()
DOCUMENTO_ABIERTO --> DOCUMENTACION_ABIERTA : completarGestion()

DOCUMENTACION_ABIERTA --> CASOS_USO_ABIERTO : abrirCasosUso()
CASOS_USO_ABIERTO --> DOCUMENTACION_ABIERTA : completarGestion()

CASOS_USO_ABIERTO --> CASO_USO_ABIERTO : crearCasoUso()
CASOS_USO_ABIERTO --> CASO_USO_ABIERTO : editarCasoUso()
CASOS_USO_ABIERTO --> CASO_USO_ABIERTO : eliminarCasoUso()
CASO_USO_ABIERTO --> CASOS_USO_ABIERTO : completarGestion()

DOCUMENTACION_ABIERTA --> REQUISITOS_FUNCIONALES_ABIERTO : abrirRequisitosFuncionales()
REQUISITOS_FUNCIONALES_ABIERTO --> DOCUMENTACION_ABIERTA : completarGestion()

REQUISITOS_FUNCIONALES_ABIERTO --> REQUISITO_FUNCIONAL_ABIERTO : crearRequisitoFuncional()
REQUISITOS_FUNCIONALES_ABIERTO --> REQUISITO_FUNCIONAL_ABIERTO : editarRequisitoFuncional()
REQUISITOS_FUNCIONALES_ABIERTO --> REQUISITO_FUNCIONAL_ABIERTO : eliminarRequisitoFuncional()
REQUISITO_FUNCIONAL_ABIERTO --> REQUISITOS_FUNCIONALES_ABIERTO : completarGestion()

DOCUMENTACION_ABIERTA --> ANALISIS_ABIERTO : analizarDocumentacion()
ANALISIS_ABIERTO --> DOCUMENTACION_ABIERTA : completarAnalisis()

ANALISIS_ABIERTO --> ESTRUCTURACION_ABIERTA : estructurarCasosUsoYRequisitos()
ESTRUCTURACION_ABIERTA --> ANALISIS_ABIERTO : completarEstructuracion()

ESTRUCTURACION_ABIERTA --> ESCENARIOS_ABIERTO : generarEscenariosPrueba()
ESCENARIOS_ABIERTO --> ESTRUCTURACION_ABIERTA : completarGeneracion()

ESCENARIOS_ABIERTO --> REVISION_ESCENARIOS_ABIERTA : revisarEscenariosGenerados()
REVISION_ESCENARIOS_ABIERTA --> ESCENARIOS_ABIERTO : completarRevision()

ESCENARIOS_ABIERTO --> KIWI_TCMS_ABIERTO : publicarEnKiwiTCMS()
KIWI_TCMS_ABIERTO --> KIWI_TCMS_ABIERTO : recibirEscenariosPrueba()
KIWI_TCMS_ABIERTO --> KIWI_TCMS_ABIERTO : almacenarEscenariosPrueba()
KIWI_TCMS_ABIERTO --> ESCENARIOS_ABIERTO : completarPublicacion()

@enduml