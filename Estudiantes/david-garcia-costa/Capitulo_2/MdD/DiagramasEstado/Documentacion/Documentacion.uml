@startuml
state Documentacion {
  [*] --> Creada

  state Creada
  state EnEdicion
  state Analizada
  state Eliminada

  Creada --> EnEdicion : editarDocumentacion()
  EnEdicion --> Analizada : analizarDocumentacion()

  Creada --> Eliminada : eliminarDocumentacion()
  EnEdicion --> Eliminada : eliminarDocumentacion()
  Analizada --> Eliminada : eliminarDocumentacion()

  Analizada --> [*]
  Eliminada --> [*]
}
@enduml